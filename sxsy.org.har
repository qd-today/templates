[
    {
        "comment": "OCR识别",
        "request": {
            "method": "POST",
            "url": "api://util/dddd/ocr",
            "headers": [
                {
                    "name": "Content-Type",
                    "value": "application/json"
                }
            ],
            "cookies": [],
            "data": "{\"img\":\"\",\"imgurl\":\"https://sxsy.org/site.jpeg\",\"old\":\"true\",\"extra_onnx_name\":\"\"}"
        },
        "rule": {
            "success_asserts": [
                {
                    "re": "200",
                    "from": "status"
                }
            ],
            "failed_asserts": [],
            "extract_variables": [
                {
                    "name": "test",
                    "re": "\"Result\": \"(.*)\"",
                    "from": "content"
                },
                {
                    "name": "t",
                    "re": "t\": \"([a-zA-Z]+)",
                    "from": "content"
                },
                {
                    "name": "sw",
                    "re": "t\": \"[a-zA-Z]+(\\d+)",
                    "from": "content"
                },
                {
                    "name": "h",
                    "re": "t\": \"[a-zA-Z]+\\d+(\\w+)",
                    "from": "content"
                }
            ]
        }
    },
    {
        "comment": "Unicode转换",
        "request": {
            "method": "POST",
            "url": "api://util/unicode",
            "headers": [],
            "cookies": [],
            "data": "content=https://{{t|lower}}{{sw}}.{{h|lower}}"
        },
        "rule": {
            "success_asserts": [
                {
                    "re": "200",
                    "from": "status"
                }
            ],
            "failed_asserts": [],
            "extract_variables": [
                {
                    "name": "d",
                    "re": "\"转换后\": \"(.*)\"",
                    "from": "content"
                }
            ]
        }
    },
    {
        "request": {
            "method": "GET",
            "url": "{{d}}",
            "headers": [],
            "cookies": [],
            "data": ""
