    },
    {
        "comment": "While 循环结束",
        "request": {
            "method": "GET",
            "url": "{% endwhile %}",
            "headers": [],
            "cookies": [],
            "data": ""
        },
        "rule": {
            "success_asserts": [],
            "failed_asserts": [],
            "extract_variables": []
        }
    },
    {
        "comment": "Print Log",
        "request": {
            "method": "POST",
            "url": "api://util/urldecode",
            "headers": [],
            "cookies": [],
            "data": "content={{ \"Successfully executed, but no available offer found.\" if boost_count | int == 0 else \"Successfully boosted \" ~ boost_count ~ \" offers.\" }}"
        },
        "rule": {
            "success_asserts": [
                {
                    "re": "200",
                    "from": "status"
                }
            ],
            "failed_asserts": [],
            "extract_variables": [
                {
                    "name": "__log__",
                    "re": "\"转换后\": \"(.*)\"",
                    "from": "content"
                }
            ]
        }
    }
]