[
    {
        "comment": "返回对应时间戳和时间",
        "request": {
            "method": "POST",
            "url": "api://util/timestamp",
            "headers": [],
            "cookies": [],
            "data": "ts=&form=&dt="
        },
        "rule": {
            "success_asserts": [
                {
                    "re": "200",
                    "from": "status"
                }
            ],
            "failed_asserts": [],
            "extract_variables": [
                {
                    "name": "sjc",
                    "re": "\"16位时间戳\"\\s*:\\s*(\\d{13})\\d{3}",
                    "from": "content"
                }
            ]
        }
    },
    {
        "comment": "计算Signature",
        "request": {
            "method": "POST",
            "url": "api://util/unicode",
            "headers": [],
            "cookies": [],
            "data": "html_unescape=false&content={{md5(\"_platform=web,_ts=\" + sjc + \",_versioin=\" + versioin + \",\")}}"
        },
        "rule": {
            "success_asserts": [
                {
                    "re": "200",
                    "from": "status"
                },
                {
                    "re": "\"状态\": \"200\"",
                    "from": "content"
                }
            ],
            "failed_asserts": [],
            "extract_variables": [
                {
                    "name": "Signature",
                    "re": "\"转换后\": \"(.*)\"",
                    "from": "content"
                }
            ]
        }
    },
    {
        "request": {
            "method": "OPTIONS",
            "url": "https://ssv-api.agilestudio.cn/api/auth/email-login?_platform=web&_versioin={{versioin|urlencode}}&_ts={{sjc|urlencode}}",
            "headers": [
                {
                    "name": "User-Agent",
                    "value": "Mozilla/5.0 (X11; Linux x86_64; rv:140.0) Gecko/20100101 Firefox/140.0"
                },
                {
                    "name": "Accept",
                    "value": "*/*"
                },
                {
                    "name": "Accept-Language",
                    "value": "zh-CN,zh;q=0.8,zh-TW;q=0.7,zh-HK;q=0.5,en-US;q=0.3,en;q=0.2"
                },
                {
                    "name": "Accept-Encoding",
                    "value": "gzip, deflate, br, zstd"
                },
                {
                    "name": "Access-Control-Request-Method",
                    "value": "POST"
                },
                {
                    "name": "Access-Control-Request-Headers",
                    "value": "content-type,x-signature"
                },
                {
                    "name": "Referer",
                    "value": "https://33tc.net/"
                },
                {
                    "name": "Origin",
                    "value": "https://33tc.net"
                },
                {
                    "name": "Connection",
                    "value": "keep-alive"
                },
                {
                    "name": "Sec-Fetch-Dest",
                    "value": "empty"
                },
                {
                    "name": "Sec-Fetch-Mode",
                    "value": "cors"
                },
                {
                    "name": "Sec-Fetch-Site",
                    "value": "cross-site"
                },
                {
                    "name": "Priority",
                    "value": "u=4"
                },
                {
                    "name": "Pragma",
                    "value": "no-cache"
                },
                {
                    "name": "Cache-Control",
                    "value": "no-cache"
                }
            ],
            "cookies": []
        },
        "rule": {
            "success_asserts": [
                {
                    "re": "200",
                    "from": "status"
                }
            ],
            "failed_asserts": [],
            "extract_variables": []
        }
    },
    {
        "request": {
            "method": "POST",
            "url": "https://ssv-api.agilestudio.cn/api/auth/email-login?_platform=web&_versioin={{versioin|urlencode}}&_ts={{sjc|urlencode}}",
            "headers": [
                {
                    "name": "User-Agent",
                    "value": "Mozilla/5.0 (X11; Linux x86_64; rv:140.0) Gecko/20100101 Firefox/140.0"
                },
                {
                    "name": "Accept",
                    "value": "application/json, text/plain, */*"
                },
                {
                    "name": "Accept-Language",
                    "value": "zh-CN,zh;q=0.8,zh-TW;q=0.7,zh-HK;q=0.5,en-US;q=0.3,en;q=0.2"
                },
                {
                    "name": "Accept-Encoding",
                    "value": "gzip, deflate, br, zstd"
                },
                {
                    "name": "Referer",
                    "value": "https://33tc.net/"
                },
                {
                    "name": "Content-Type",
                    "value": "application/json;charset=utf-8"
                },
                {
                    "name": "X-Signature",
                    "value": "{{Signature}}"
                },
                {
                    "name": "Origin",
                    "value": "https://33tc.net"
                },
                {
                    "name": "Connection",
                    "value": "keep-alive"
                },
                {
                    "name": "Sec-Fetch-Dest",
                    "value": "empty"
                },
                {
                    "name": "Sec-Fetch-Mode",
                    "value": "cors"
                },
                {
                    "name": "Sec-Fetch-Site",
                    "value": "cross-site"
                },
                {
                    "name": "Priority",
                    "value": "u=0"
                },
                {
                    "name": "Pragma",
                    "value": "no-cache"
                },
                {
                    "name": "Cache-Control",
                    "value": "no-cache"
                }
            ],
            "cookies": [],
            "data": "{\"email\":\"{{email}}\",\"password\":\"{{password}}\"}",
            "mimeType": "application/json;charset=utf-8"
        },
        "rule": {
            "success_asserts": [
                {
                    "re": "200",
                    "from": "status"
                }
            ],
            "failed_asserts": [
                {
                    "re": "签名错误",
                    "from": "content"
                },
                {
                    "re": "账号或者密码错误",
                    "from": "content"
                }
            ],
            "extract_variables": [
                {
                    "name": "token",
                    "re": "\"token\"\\s*:\\s*\"([^\"]+)\"",
                    "from": "content"
                }
            ]
        }
    },
