[
    {
        "comment": "基础签到：获取登录信息并提取用户资料",
        "request": {
            "method": "GET",
            "url": "https://bbs.dji.com/api/v2/users/login-info?device=desktop&t={{ multiply(timestamp('float'), 1000)|int }}",
            "headers": [
                {
                    "name": "User-Agent",
                    "value": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/122.0.0.0 Safari/537.36"
                },
                {
                    "name": "Accept",
                    "value": "application/json, text/plain, */*"
                },
                {
                    "name": "Referer",
                    "value": "https://bbs.dji.com/"
                },
                {
                    "name": "Cookie",
                    "value": "{{cookie}}"
                }
            ],
            "cookies": []
        },
        "rule": {
            "success_asserts": [
                {
                    "re": "200",
                    "from": "status"
                },
                {
                    "re": "\"item\":\\s*\\{",
                    "from": "content"
                }
            ],
            "failed_asserts": [
                {
                    "re": "\"item\":\\s*null|您需要先登录",
                    "from": "content"
                }
            ],
            "extract_variables": [
                {
                    "name": "uid",
                    "re": "\"id\":\\s*(\\d+)",
                    "from": "content"
                },
                {
                    "name": "uuid",
                    "re": "\"uuid\":\\s*\"([^\"]+)\"",
                    "from": "content"
                },
                {
                    "name": "username",
                    "re": "\"name\":\\s*\"([^\"]+)\"",
                    "from": "content"
                },
                {
                    "name": "start_credits",
                    "re": "\"credits\":\\s*(\\d+)",
                    "from": "content"
                },
                {
                    "name": "login_signed",
                    "re": "\"signed\":\\s*(true|false)",
                    "from": "content"
                }
            ]
        }
    },
    {
        "comment": "基础签到：查询签到状态",
        "request": {
            "method": "GET",
            "url": "https://bbs.dji.com/api/v2/home/paulsigns/user?device=desktop&t={{ multiply(timestamp('float'), 1000)|int }}",
            "headers": [
                {
                    "name": "User-Agent",
                    "value": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/122.0.0.0 Safari/537.36"
                },
                {
                    "name": "Accept",
                    "value": "application/json, text/plain, */*"
                },
                {
                    "name": "Referer",
                    "value": "https://bbs.dji.com/"
                },
                {
                    "name": "Cookie",
                    "value": "{{cookie}}"
                }
            ],
            "cookies": []
        },
        "rule": {
            "success_asserts": [
                {
                    "re": "200",
                    "from": "status"
                },
                {
                    "re": "\"signed\":\\s*(true|false)",
                    "from": "content"
                }
            ],
            "failed_asserts": [
                {
                    "re": "您需要先登录",
                    "from": "content"
                }
            ],
            "extract_variables": [
                {
                    "name": "pre_signed",
                    "re": "\"signed\":\\s*(true|false)",
                    "from": "content"
                },
                {
                    "name": "sign_days",
                    "re": "\"days\":\\s*(\\d+)",
                    "from": "content"
                },
                {
                    "name": "sign_lasted",
                    "re": "\"lasted\":\\s*(\\d+)",
                    "from": "content"
                }
            ]
        }
    },
    {
        "request": {
            "method": "GET",
            "url": "{% if pre_signed != \"true\" %}",
            "headers": [],
            "cookies": []
        },
        "rule": {
            "success_asserts": [],
            "failed_asserts": [],
            "extract_variables": []
        }
    },
    {
        "comment": "基础签到：执行每日签到",
        "request": {
            "method": "POST",
            "url": "https://bbs.dji.com/api/v2/home/paulsigns/sign?device=desktop",
            "headers": [
                {
                    "name": "Origin",
                    "value": "https://bbs.dji.com"
                },
                {
                    "name": "Referer",
                    "value": "https://bbs.dji.com/"
                },
                {
                    "name": "User-Agent",
                    "value": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/122.0.0.0 Safari/537.36"
                },
                {
                    "name": "Accept",
                    "value": "application/json, text/plain, */*"
                },
                {
                    "name": "Content-Type",
                    "value": "application/x-www-form-urlencoded"
                },
                {
                    "name": "Cookie",
                    "value": "{{cookie}}"
                }
            ],
            "cookies": [],
            "data": "",
            "mimeType": "application/x-www-form-urlencoded"
        },
        "rule": {
            "success_asserts": [
                {
                    "re": "200",
                    "from": "status"
                }
            ],
            "failed_asserts": [
                {
                    "re": "您需要先登录才能继续本操作",
                    "from": "content"
                }
            ],
            "extract_variables": [
                {
                    "name": "sign_success",
                    "re": "\"success\":\\s*(\\w+)",
                    "from": "content"
                },
                {
                    "name": "increased",
                    "re": "\"increased\":\\s*(\\d+)",
                    "from": "content"
                }
            ]
        }
    },
    {
        "request": {
            "method": "GET",
            "url": "{% endif %}",
            "headers": [],
            "cookies": []
        },
        "rule": {
            "success_asserts": [],
            "failed_asserts": [],
            "extract_variables": []
        }
    },
    {
        "comment": "空间访问积分：访问自己的个人空间（按规则可得 5 分）",
        "request": {
            "method": "GET",
            "url": "https://bbs.dji.com/pro/user-center?uid={{uid}}&uuid={{uuid}}&do=thread",
            "headers": [
                {
                    "name": "User-Agent",
                    "value": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/122.0.0.0 Safari/537.36"
                },
                {
                    "name": "Accept",
                    "value": "text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8"
                },
                {
                    "name": "Referer",
                    "value": "https://bbs.dji.com/"
                },
                {
                    "name": "Cookie",
                    "value": "{{cookie}}"
                }
            ],
            "cookies": []
        },
        "rule": {
            "success_asserts": [
                {
                    "re": "200",
                    "from": "status"
                }
            ],
            "failed_asserts": [
                {
                    "re": "您需要先登录才能继续本操作",
                    "from": "content"
                }
            ],
            "extract_variables": [
                {
                    "name": "own_space_status",
                    "re": "(\\d+)",
                    "from": "status"
                }
            ]
        }
    },
    {
        "comment": "空间访问积分：获取公开帖子列表并提取他人空间候选",
        "request": {
            "method": "GET",
            "url": "https://bbs.dji.com/api/v2/forum/thread/list?device=desktop&channel_slug=home-square-all&limit=10&offset=10&sort_type=latest_posts",
            "headers": [
                {
                    "name": "User-Agent",
                    "value": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/122.0.0.0 Safari/537.36"
                },
                {
                    "name": "Accept",
                    "value": "application/json, text/plain, */*"
                },
                {
                    "name": "Referer",
                    "value": "https://bbs.dji.com/"
                },
                {
                    "name": "Cookie",
                    "value": "{{cookie}}"
                }
            ],
            "cookies": []
        },
        "rule": {
            "success_asserts": [
                {
                    "re": "200",
                    "from": "status"
                },
                {
                    "re": "\"items\":\\s*\\[",
                    "from": "content"
                }
            ],
            "failed_asserts": [],
            "extract_variables": [
                {
                    "name": "author_uids",
                    "re": "/\"author\":\\{\"id\":(\\d+),\"uuid\":\"[^\"]+\"/g",
                    "from": "content"
                },
                {
                    "name": "author_uuids",
                    "re": "/\"author\":\\{\"id\":\\d+,\"uuid\":\"([^\"]+)\"/g",
                    "from": "content"
                }
            ]
        }
    },
    {
        "request": {
            "method": "GET",
            "url": "{% for _ in range(10) %}",
            "headers": [],
            "cookies": []
        },
        "rule": {
            "success_asserts": [],
            "failed_asserts": [],
            "extract_variables": []
        }
    },
    {
        "request": {
            "method": "GET",
            "url": "{% if int(loop_index0) < len(author_uids) and int(loop_index0) < len(author_uuids) %}",
            "headers": [],
            "cookies": []
        },
        "rule": {
            "success_asserts": [],
            "failed_asserts": [],
