    {
        "comment": "获取最终积分",
        "request": {
            "method": "GET",
            "url": "https://bbs.dji.com/api/v2/users/login-info?device=desktop&t={{ multiply(timestamp('float'), 1000)|int }}",
            "headers": [
                {
                    "name": "User-Agent",
                    "value": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/122.0.0.0 Safari/537.36"
                },
                {
                    "name": "Accept",
                    "value": "application/json, text/plain, */*"
                },
                {
                    "name": "Referer",
                    "value": "https://bbs.dji.com/"
                },
                {
                    "name": "Cookie",
                    "value": "{{cookie}}"
                }
            ],
            "cookies": []
        },
        "rule": {
            "success_asserts": [
                {
                    "re": "200",
                    "from": "status"
                },
                {
                    "re": "\"item\":\\s*\\{",
                    "from": "content"
                }
            ],
            "failed_asserts": [
                {
                    "re": "\"item\":\\s*null|您需要先登录",
                    "from": "content"
                }
            ],
            "extract_variables": [
                {
                    "name": "final_credits",
                    "re": "\"credits\":\\s*(\\d+)",
                    "from": "content"
                },
                {
                    "name": "final_signed",
                    "re": "\"signed\":\\s*(true|false)",
                    "from": "content"
                }
            ]
        }
    },
    {
        "comment": "积分账本：获取最近任务奖励记录",
        "request": {
            "method": "GET",
            "url": "https://bbs.dji.com/api/v2/users/credits/logs?device=desktop&page=1&page_size=20",
            "headers": [
                {
                    "name": "User-Agent",
                    "value": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/122.0.0.0 Safari/537.36"
                },
                {
                    "name": "Accept",
                    "value": "application/json, text/plain, */*"
                },
                {
                    "name": "Referer",
                    "value": "https://bbs.dji.com/"
                },
                {
                    "name": "Cookie",
                    "value": "{{cookie}}"
                }
            ],
            "cookies": []
        },
        "rule": {
            "success_asserts": [
                {
                    "re": "200",
                    "from": "status"
                },
                {
                    "re": "\"list\":\\s*\\[",
                    "from": "content"
                }
            ],
            "failed_asserts": [
                {
                    "re": "\"item\":\\s*null|您需要先登录",
                    "from": "content"
                }
            ],
            "extract_variables": [
                {
                    "name": "credit_log_types",
                    "re": "/\"type\":\\s*\"([^\"]+)\"/g",
                    "from": "content"
                },
                {
                    "name": "credit_log_changes",
                    "re": "/\"changeCredits\":\\s*(-?\\d+)/g",
                    "from": "content"
                },
                {
                    "name": "credit_log_balances",
                    "re": "/\"availableCredits\":\\s*(\\d+)/g",
                    "from": "content"
                }
            ]
        }
    },
    {
        "comment": "生成多行日志",
        "request": {
            "method": "POST",
            "url": "api://util/unicode",
            "headers": [
                {
                    "name": "Content-Type",
                    "value": "application/x-www-form-urlencoded"
                }
            ],
            "cookies": [],
            "data": "html_unescape=false&content={% set final_points = final_credits|default('0')|int %}{% set other_ok_count = [author_uids|default([])|length, author_uuids|default([])|length, 10]|min %}{% set other_points = [((credit_log_types|default([]))|select('equalto', '访问他人空间奖励')|list|length), 5]|min %}{% set own_points = 5 if ('访问个人空间奖励' in (credit_log_types|default([])) or '登录奖励' in (credit_log_types|default([])) or own_space_status|default('0')|int == 200) else 0 %}{% set sign_ok = final_signed|default(pre_signed|default(login_signed|default('false'))) == 'true' %}{% set sign_points = 2 if sign_ok and ('签到奖励' in (credit_log_types|default([])) or (sign_success|default('false')) == 'true') else 0 %}{% set ledger_points = sign_points + own_points + other_points %}{% set display_start = (final_points - ledger_points) if ledger_points > 0 else start_credits|default('?') %}{% set own_ok = own_space_status|default('0')|int == 200 or own_points > 0 %}{% set task_status = '完成' if sign_ok and own_ok and other_ok_count >= 10 else ('部分完成' if sign_ok or own_ok or other_ok_count > 0 else '失败') %}{{ ('【个人信息】\\r\\n' ~ '用户：【' ~ (username|default('')) ~ '】 UID：【' ~ (uid|default('')) ~ '】\\r\\n' ~ '任务情况：【' ~ task_status ~ '】 连签天数：【' ~ (sign_days|default('?')) ~ '】\\r\\n\\r\\n' ~ '【任务情况】\\r\\n' ~ '签到：【' ~ ('成功' if sign_ok else '失败') ~ '】\\r\\n' ~ '个人空间：【' ~ ('成功' if own_ok else '失败') ~ '】\\r\\n' ~ '他人空间：【成功' ~ other_ok_count ~ '次】\\r\\n\\r\\n' ~ '【积分情况】\\r\\n' ~ '积分变化：【' ~ display_start ~ ' -> ' ~ (final_credits|default('?')) ~ '】\\r\\n' ~ '账本拆分：【签到 +' ~ sign_points ~ '；个人空间 +' ~ own_points ~ '；他人空间 +' ~ other_points ~ '】')|urlencode }}",
            "mimeType": "application/x-www-form-urlencoded"
        },
        "rule": {
            "success_asserts": [
                {
                    "re": "200",
                    "from": "status"
                },
                {
                    "re": "\"状态\": \"200\"",
                    "from": "content"
                }
            ],
            "failed_asserts": [],
            "extract_variables": [
                {
                    "name": "__log__",
                    "re": "\"转换后\": \"([\\s\\S]*?)\",\\s*\"状态\"",
                    "from": "content"
                }
            ]
        }
    }
]