[
    {
        "comment": "1. 获取用户信息",
        "request": {
            "method": "GET",
            "url": "https://cloudstudio.net/api/user/info",
            "headers": [
                {
                    "name": "X-XSRF-TOKEN",
                    "value": "{{xsrf}}"
                },
                {
                    "name": "Cookie",
                    "value": "{{cookie}}"
                },
                {
                    "name": "X-Requested-With",
                    "value": "XMLHttpRequest"
                }
            ],
            "cookies": []
        },
        "rule": {
            "success_asserts": [
                {
                    "re": "200",
                    "from": "status"
                }
            ],
            "failed_asserts": [],
            "extract_variables": [
                {
                    "name": "nickName",
                    "re": "\"nickName\":\"(.*?)\"",
                    "from": "content"
                }
            ]
        }
    },
    {
        "comment": "2. 执行签到",
        "request": {
            "method": "POST",
            "url": "https://cloudstudio.net/api/billing/activityTask/SIGN_IN_2025Q3/_reward",
            "headers": [
                {
                    "name": "X-XSRF-TOKEN",
                    "value": "{{xsrf}}"
                },
                {
                    "name": "Cookie",
                    "value": "{{cookie}}"
                },
                {
                    "name": "X-Requested-With",
                    "value": "XMLHttpRequest"
                },
                {
                    "name": "Content-Length",
                    "value": "0"
                }
            ],
            "cookies": []
        },
        "rule": {
            "success_asserts": [
                {
                    "re": "200",
                    "from": "status"
                }
            ],
            "failed_asserts": [],
            "extract_variables": [
                {
                    "name": "reward",
                    "re": "\"rewardNum\":(\\d+)",
                    "from": "content"
                }
            ]
        }
    },
    {
        "comment": "3. 获取资源包余额 (列表提取)",
        "request": {
            "method": "GET",
            "url": "https://cloudstudio.net/api/billing/resource/package?pageNumber=0&pageSize=10",
            "headers": [
                {
                    "name": "X-XSRF-TOKEN",
                    "value": "{{xsrf}}"
                },
                {
                    "name": "Cookie",
                    "value": "{{cookie}}"
                }
            ],
            "cookies": []
        },
        "rule": {
            "success_asserts": [
                {
                    "re": "200",
                    "from": "status"
                }
            ],
            "failed_asserts": [],
            "extract_variables": [
                {
                    "name": "p_names",
                    "re": "/\"name\":\"(.*?)\"/g",
                    "from": "content"
                },
                {
                    "name": "p_totals",
                    "re": "/\"total\":(\\d+)/g",
                    "from": "content"
                },
                {
                    "name": "p_useds",
                    "re": "/\"used\":(\\d+)/g",
                    "from": "content"
                },
                {
                    "name": "p_exps",
                    "re": "/\"expiredTime\":\"(.*?)\"/g",
                    "from": "content"
                }
            ]
        }
    },
    {
        "comment": "4. 汇总日志并计算机时",
        "request": {
            "method": "POST",
            "url": "api://util/urldecode",
            "headers": [],
            "cookies": [],
            "data": "content=用户 {{nickName}} 签到成功！{{'\\n'}}获得奖励：{{ (reward|default(0)|int / 100000000)|round(2) }} 机时{{'\\n'}}最新可用资源为：{{'\\n'}}已用 | 一共 | 到期时间 | 资源名称{{'\\n'}}{% for name in p_names -%}{{ (p_useds[loop.index0]|int / 100000000)|round(2) }} | {{ (p_totals[loop.index0]|int / 100000000)|int }} 机时 | {{p_exps[loop.index0]|replace('T',' ')|replace('.000+00:00','')}} | {{name}}{% if not loop.last %}{{'\\n'}}{% endif %}{% endfor %}"
        },
        "rule": {
            "success_asserts": [],
            "failed_asserts": [],
            "extract_variables": [
                {
                    "name": "__log__",
                    "re": "\"转换后\": \"(.*)\"",
                    "from": "content"
                }
            ]
        }
    }
]