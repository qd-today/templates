[
    {
        "comment": "",
        "request": {
            "method": "GET",
            "url": "https://pingkai.cn/accounts/login?redirect_to=https%3A%2F%2Fpingkai.cn%2Ftidbcommunity%2Fforum%2F",
            "headers": [
                {
                    "name": "User-Agent",
                    "value": "Mozilla/5.0 (X11; Linux x86_64; rv:140.0) Gecko/20100101 Firefox/140.0"
                },
                {
                    "name": "Accept",
                    "value": "text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8"
                },
                {
                    "name": "Accept-Language",
                    "value": "zh-hans"
                },
                {
                    "name": "Accept-Encoding",
                    "value": "gzip, deflate, br, zstd"
                },
                {
                    "name": "Connection",
                    "value": "keep-alive"
                },
                {
                    "name": "Sec-Fetch-Dest",
                    "value": "document"
                },
                {
                    "name": "Sec-Fetch-Mode",
                    "value": "navigate"
                },
                {
                    "name": "Sec-Fetch-Site",
                    "value": "same-origin"
                },
                {
                    "name": "Pragma",
                    "value": "no-cache"
                },
                {
                    "name": "Cache-Control",
                    "value": "no-cache"
                },
                {
                    "name": "Cookie",
                    "value": "csrftoken="
                }
            ],
            "cookies": []
        },
        "rule": {
            "success_asserts": [
                {
                    "re": "200",
                    "from": "status"
                }
            ],
            "failed_asserts": [],
            "extract_variables": [
                {
                    "name": "csrftoken",
                    "re": "csrftoken=([^;]+)",
                    "from": "header"
                }
            ]
        }
    },
    {
        "request": {
            "method": "POST",
            "url": "https://pingkai.cn/accounts/api/login/password",
            "headers": [
                {
                    "name": "User-Agent",
                    "value": "Mozilla/5.0 (X11; Linux x86_64; rv:140.0) Gecko/20100101 Firefox/140.0"
                },
                {
                    "name": "Accept",
                    "value": "application/json, text/plain, */*"
                },
                {
                    "name": "Accept-Language",
                    "value": "zh-hans"
                },
                {
                    "name": "Accept-Encoding",
                    "value": "gzip, deflate, br, zstd"
                },
                {
                    "name": "Referer",
                    "value": "https://pingkai.cn/accounts/login"
                },
                {
                    "name": "Content-Type",
                    "value": "application/json"
                },
                {
                    "name": "Origin",
                    "value": "https://pingkai.cn"
                },
                {
                    "name": "Connection",
                    "value": "keep-alive"
                },
                {
                    "name": "Sec-Fetch-Dest",
                    "value": "empty"
                },
                {
                    "name": "Sec-Fetch-Mode",
                    "value": "cors"
                },
                {
                    "name": "Sec-Fetch-Site",
                    "value": "same-origin"
                },
                {
                    "name": "Priority",
                    "value": "u=0"
                },
                {
                    "name": "Pragma",
                    "value": "no-cache"
                },
                {
                    "name": "Cache-Control",
                    "value": "no-cache"
                },
                {
                    "name": "X-CSRFTOKEN",
                    "value": "{{csrftoken}}"
                }
            ],
            "cookies": [],
            "data": "{\"identifier\":\"{{username}}\",\"password\":\"{{password}}\",\"redirect_to\":\"\"}",
            "mimeType": "application/json"
        },
        "rule": {
            "success_asserts": [
                {
                    "re": "200",
                    "from": "status"
                }
            ],
            "failed_asserts": [
                {
                    "re": "用户名或密码错误",
                    "from": "content"
                }
            ],
            "extract_variables": [
                {
                    "name": "csrftoken",
                    "re": "csrftoken=([^;]+)",
                    "from": "header"
                }
            ]
        }
    },
    {
        "request": {
            "method": "POST",
            "url": "https://pingkai.cn/accounts/api/points/daily-checkin",
            "headers": [
                {
                    "name": "User-Agent",
                    "value": "Mozilla/5.0 (X11; Linux x86_64; rv:140.0) Gecko/20100101 Firefox/140.0"
                },
                {
                    "name": "Accept",
                    "value": "application/json, text/plain, */*"
                },
                {
                    "name": "Accept-Language",
                    "value": "zh-hans"
                },
                {
                    "name": "Accept-Encoding",
                    "value": "gzip, deflate, br, zstd"
                },
                {
                    "name": "Origin",
                    "value": "https://pingkai.cn"
                },
                {
                    "name": "Connection",
                    "value": "keep-alive"
                },
                {
                    "name": "Referer",
                    "value": "https://pingkai.cn/tidbcommunity/member"
                },
                {
                    "name": "Sec-Fetch-Dest",
                    "value": "empty"
                },
                {
                    "name": "Sec-Fetch-Mode",
                    "value": "cors"
                },
                {
                    "name": "Sec-Fetch-Site",
                    "value": "same-origin"
                },
                {
                    "name": "Priority",
                    "value": "u=0"
                },
                {
                    "name": "Pragma",
                    "value": "no-cache"
                },
                {
                    "name": "Cache-Control",
                    "value": "no-cache"
                },
                {
                    "name": "X-CSRFTOKEN",
                    "value": "{{csrftoken}}"
                }
            ],
            "cookies": []
        },
        "rule": {
            "success_asserts": [
                {
                    "re": "200",
                    "from": "status"
                }
            ],
            "failed_asserts": [
                {
                    "re": "已经签过到了",
                    "from": "content"
                }
            ],
            "extract_variables": [
                {
                    "name": "continues_checkin_count",
                    "re": "\"continues_checkin_count\":(\\d+)",
                    "from": "content"
                },
                {
                    "name": "points",
                    "re": "\"points\":(\\d+)",
                    "from": "content"
                },
                {
                    "name": "tomorrow_points",
                    "re": "\"tomorrow_points\":(\\d+)",
                    "from": "content"
                }
            ]
        }
    },
    {
