    {
        "comment": "获取积分",
        "request": {
            "method": "GET",
            "url": "https://south-plus.net/userpay.php",
            "headers": [
                {
                    "name": "User-Agent",
                    "value": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/132.0.0.0 Safari/537.36"
                },
                {
                    "name": "Accept",
                    "value": "text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8"
                },
                {
                    "name": "Accept-Language",
                    "value": "zh-CN,zh;q=0.9"
                },
                {
                    "name": "Referer",
                    "value": "https://south-plus.net/plugin.php?H_name-tasks.html"
                }
            ],
            "cookies": []
        },
        "rule": {
            "success_asserts": [
                {
                    "re": "200",
                    "from": "status"
                }
            ],
            "failed_asserts": [
                {
                    "re": "您没有登录或者您没有权限访问此页面|您还没有登录|您没有登录|没有权限",
                    "from": "content"
                }
            ],
            "extract_variables": [
                {
                    "name": "log_value",
                    "re": "SP币:\\s*<span class=\"b f16 s3\">(.+?)<",
                    "from": "content"
                }
            ]
        }
    },
    {
        "comment": "生成多行日志",
        "request": {
            "method": "POST",
            "url": "api://util/unicode",
            "headers": [
                {
                    "name": "Content-Type",
                    "value": "application/x-www-form-urlencoded"
                }
            ],
            "cookies": [],
            "data": "html_unescape=false&content={{ ('【周常状态】\\r\\n' ~ '周常执行：【' ~ ('已跳过，本周已完成' if weekly_completed_marker else '已执行本周流程') ~ '】\\r\\n' ~ '【任务领取】\\r\\n' ~ '周常申请：【' ~ ('已跳过' if weekly_completed_marker else (apply_week|default(''))) ~ '】\\r\\n' ~ '日常申请：【' ~ (apply_day|default('')) ~ '】\\r\\n' ~ '【任务完成】\\r\\n' ~ '周常完成：【' ~ ('已跳过' if weekly_completed_marker else (finish_week|default(''))) ~ '】\\r\\n' ~ '日常完成：【' ~ (finish_day|default('')) ~ '】\\r\\n' ~ '【积分信息】\\r\\n' ~ 'SP币：【' ~ (log_value|default('?')) ~ '】')|urlencode }}",
            "mimeType": "application/x-www-form-urlencoded"
        },
        "rule": {
            "success_asserts": [
                {
                    "re": "200",
                    "from": "status"
                },
                {
                    "re": "\"状态\": \"200\"",
                    "from": "content"
                }
            ],
            "failed_asserts": [],
            "extract_variables": [
                {
                    "name": "__log__",
                    "re": "\"转换后\": \"([\\s\\S]*?)\",\\s*\"状态\"",
                    "from": "content"
                }
            ]
        }
    }
]