[
    {
        "comment": "打开任务页并提取 verifyhash",
        "request": {
            "method": "GET",
            "url": "https://south-plus.net/plugin.php?H_name-tasks.html",
            "headers": [
                {
                    "name": "User-Agent",
                    "value": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/132.0.0.0 Safari/537.36"
                },
                {
                    "name": "Accept",
                    "value": "text/html,application/xhtml+xml,application/xml;q=0.9,image/avif,image/webp,image/apng,*/*;q=0.8"
                },
                {
                    "name": "Accept-Language",
                    "value": "zh-CN,zh;q=0.9"
                },
                {
                    "name": "Referer",
                    "value": "https://south-plus.net/"
                },
                {
                    "name": "Cookie",
                    "value": "{{ cookie }}"
                }
            ],
            "cookies": []
        },
        "rule": {
            "success_asserts": [
                {
                    "re": "200",
                    "from": "status"
                }
            ],
            "failed_asserts": [
                {
                    "re": "您还没有登录|您没有登录|没有权限|暂时不能使用此功能",
                    "from": "content"
                }
            ],
            "extract_variables": [
                {
                    "name": "verifyhash",
                    "re": "verifyhash\\s*=\\s*'([^']+)'",
                    "from": "content"
                }
            ]
        }
    },
    {
        "comment": "打开已完成任务页并提取周常完成标记",
        "request": {
            "method": "GET",
            "url": "https://south-plus.net/plugin.php?H_name-tasks-actions-endtasks.html.html",
            "headers": [
                {
                    "name": "User-Agent",
                    "value": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/132.0.0.0 Safari/537.36"
                },
                {
                    "name": "Accept",
                    "value": "text/html,application/xhtml+xml,application/xml;q=0.9,image/avif,image/webp,image/apng,*/*;q=0.8"
                },
                {
                    "name": "Accept-Language",
                    "value": "zh-CN,zh;q=0.9"
                },
                {
                    "name": "Referer",
                    "value": "https://south-plus.net/plugin.php?H_name-tasks.html"
                },
                {
                    "name": "Cookie",
                    "value": "{{ cookie }}"
                }
            ],
            "cookies": []
        },
        "rule": {
            "success_asserts": [
                {
                    "re": "200",
                    "from": "status"
                }
            ],
            "failed_asserts": [
                {
                    "re": "您还没有登录|您没有登录|没有权限|暂时不能使用此功能",
                    "from": "content"
                }
            ],
            "extract_variables": [
                {
                    "name": "weekly_completed_marker",
                    "re": "<td class=\"h\" colspan=\"4\">您已完成任务</td>[\\s\\S]*?<img src=\"hack/tasks/image/weekly\\.png\"[^>]*>[\\s\\S]*?<a><b>周常</b></a>[\\s\\S]*?<img src=\"hack/tasks/image/end\\.png\">[\\s\\S]*?<tbody id=\"(showb_14)\" style=\"display:none;\">",
                    "from": "content"
                }
            ]
        }
    },
    {
        "comment": "未命中周常完成标记时领取周常任务",
        "request": {
            "method": "GET",
            "url": "{% if not weekly_completed_marker %}",
            "headers": [],
            "cookies": [],
            "data": ""
        },
        "rule": {
            "success_asserts": [],
            "failed_asserts": [],
            "extract_variables": []
        }
    },
    {
        "comment": "领取周常任务",
        "request": {
            "method": "GET",
            "url": "https://south-plus.net/plugin.php?H_name=tasks&action=ajax&actions=job&cid=14&nowtime={{ multiply(timestamp('float'), 1000)|int }}&verify={{ verifyhash|urlencode }}",
            "headers": [
                {
                    "name": "User-Agent",
                    "value": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/132.0.0.0 Safari/537.36"
                },
                {
                    "name": "Accept",
                    "value": "text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8"
                },
                {
                    "name": "Accept-Language",
                    "value": "zh-CN,zh;q=0.9"
                },
                {
                    "name": "Referer",
                    "value": "https://south-plus.net/plugin.php?H_name-tasks.html"
                }
            ],
            "cookies": []
        },
        "rule": {
            "success_asserts": [
                {
                    "re": "200",
                    "from": "status"
                }
            ],
            "failed_asserts": [
                {
                    "re": "您还没有登录|您没有登录|没有权限|暂时不能使用此功能",
                    "from": "content"
                }
            ],
            "extract_variables": [
                {
                    "name": "apply_week",
                    "re": "<!\\[CDATA\\[(.*?)\\]\\]>",
                    "from": "content"
                }
            ]
        }
    },
    {
        "comment": "周常领取条件结束",
        "request": {
            "method": "GET",
            "url": "{% endif %}",
            "headers": [],
            "cookies": [],
            "data": ""
        },
        "rule": {
            "success_asserts": [],
            "failed_asserts": [],
            "extract_variables": []
        }
    },
