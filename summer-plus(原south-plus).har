[
    {
        "comment": "打开新任务选择页并提取 verifyhash 和周常申请标记",
        "request": {
            "method": "GET",
            "url": "https://south-plus.net/plugin.php?H_name-tasks.html",
            "headers": [
                {
                    "name": "User-Agent",
                    "value": "{{ ua }}"
                },
                {
                    "name": "Accept",
                    "value": "text/html,application/xhtml+xml,application/xml;q=0.9,image/avif,image/webp,image/apng,*/*;q=0.8"
                },
                {
                    "name": "Accept-Language",
                    "value": "zh-CN,zh;q=0.9"
                },
                {
                    "name": "Referer",
                    "value": "https://south-plus.net/"
                },
                {
                    "name": "Cookie",
                    "value": "{{ cookie }}"
                }
            ],
            "cookies": []
        },
        "rule": {
            "success_asserts": [
                {
                    "re": "200",
                    "from": "status"
                }
            ],
            "failed_asserts": [
                {
                    "re": "您还没有登录|您没有登录|没有权限|暂时不能使用此功能",
                    "from": "content"
                }
            ],
            "extract_variables": [
                {
                    "name": "verifyhash",
                    "re": "verifyhash\\s*=\\s*'([^']+)'",
                    "from": "content"
                },
                {
                    "name": "weekly_available_marker",
                    "re": "(<td class=\"h\" colspan=\"4\">社区论坛任务</td>[\\s\\S]*?<img src=\"hack/tasks/image/weekly\\.png\"[^>]*>[\\s\\S]*?<b>周常</b>[\\s\\S]*?(?:startjob\\('14'\\);[\\s\\S]*?按这申请此任务|按这申请此任务[\\s\\S]*?startjob\\('14'\\);))",
                    "from": "content"
                },
                {
                    "name": "daily_available_marker",
                    "re": "(<td class=\"h\" colspan=\"4\">社区论坛任务</td>[\\s\\S]*?<img src=\"hack/tasks/image/Nichijou\\.png\"[^>]*>[\\s\\S]*?<b>日常</b>[\\s\\S]*?(?:startjob\\('15'\\);[\\s\\S]*?按这申请此任务|按这申请此任务[\\s\\S]*?startjob\\('15'\\);))",
                    "from": "content"
                }
            ]
        }
    },
    {
        "comment": "命中新任务选择周常标记时领取周常任务",
        "request": {
            "method": "GET",
            "url": "{% if weekly_available_marker %}",
            "headers": [],
            "cookies": [],
            "data": ""
        },
        "rule": {
            "success_asserts": [],
            "failed_asserts": [],
            "extract_variables": []
        }
    },
    {
        "comment": "领取周常任务",
        "request": {
            "method": "GET",
            "url": "https://south-plus.net/plugin.php?H_name=tasks&action=ajax&actions=job&cid=14&nowtime={{ multiply(timestamp('float'), 1000)|int }}&verify={{ verifyhash|urlencode }}",
            "headers": [
                {
                    "name": "User-Agent",
                    "value": "{{ ua }}"
                },
                {
                    "name": "Accept",
                    "value": "text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8"
                },
                {
                    "name": "Accept-Language",
                    "value": "zh-CN,zh;q=0.9"
                },
                {
                    "name": "Referer",
                    "value": "https://south-plus.net/plugin.php?H_name-tasks.html"
                },
                {
                    "name": "Cookie",
                    "value": "{{ cookie }}"
                }
            ],
            "cookies": []
        },
        "rule": {
            "success_asserts": [
                {
                    "re": "200",
                    "from": "status"
                }
            ],
            "failed_asserts": [
                {
                    "re": "您还没有登录|您没有登录|没有权限|暂时不能使用此功能",
                    "from": "content"
                }
            ],
            "extract_variables": [
                {
                    "name": "apply_week",
                    "re": "<!\\[CDATA\\[(.*?)\\]\\]>",
                    "from": "content"
                }
            ]
        }
    },
    {
        "comment": "周常领取条件结束",
        "request": {
            "method": "GET",
            "url": "{% endif %}",
            "headers": [],
            "cookies": [],
            "data": ""
        },
        "rule": {
            "success_asserts": [],
            "failed_asserts": [],
            "extract_variables": []
        }
    },
    {
        "comment": "命中新任务选择日常标记时领取日常任务",
        "request": {
            "method": "GET",
            "url": "{% if daily_available_marker %}",
            "headers": [],
            "cookies": [],
            "data": ""
        },
        "rule": {
            "success_asserts": [],
