[
    {
        "comment": "签到",
        "request": {
            "method": "POST",
            "url": "https://user-api.smzdm.com/checkin",
            "headers": [
                {
                    "name": "Content-Type",
                    "value": "application/x-www-form-urlencoded"
                },
                {
                    "name": "User-Agent",
                    "value": "smzdm_android_V10.4.26 rv:866 (Redmi Note 3;Android10.0;zh)smzdmapp"
                },
                {
                    "name": "Cookie",
                    "value": "{{cookie}}"
                }
            ],
            "cookies": [],
            "data": "weixin=1&basic_v=0&f=android&v=10.4.26&time={{timestamp()|int * 1000}}&sign={{(\"basic_v=0&f=android&time=\" ~ (timestamp()|int * 1000)|string ~ \"&v=10.4.26&weixin=1&key=apr1$AwP!wRRT$gJ/q.X24poeBInlUJC\")|md5|upper}}"
        },
        "rule": {
            "success_asserts": [
                {
                    "re": "\"error_code\":\\s*\"0\"",
                    "from": "content"
                }
            ],
            "failed_asserts": [
                {
                    "re": "\"error_code\":\\s*11111",
                    "from": "content"
                }
            ],
            "extract_variables": [
                {
                    "re": "\"daily_num\":\\s*(\\d+)",
                    "from": "content",
                    "name": "daily_num"
                },
                {
                    "re": "\"cgold\":\\s*(\\d+)",
                    "from": "content",
                    "name": "cgold"
                },
                {
                    "re": "\"pre_re_silver\":\\s*(\\d+)",
                    "from": "content",
                    "name": "pre_re_silver"
                },
                {
                    "re": "\"error_msg\":\\s*\"([^\"]+)\"",
                    "from": "content",
                    "name": "checkin_msg"
                }
            ]
        }
    },
    {
        "comment": "延时1秒",
        "request": {
            "method": "GET",
            "url": "api://util/delay/1",
            "headers": [],
            "cookies": [],
            "data": ""
        },
        "rule": {
            "success_asserts": [
                {
                    "re": "200",
                    "from": "status"
                }
            ]
        }
    },
    {
        "comment": "抽奖",
        "request": {
            "method": "POST",
            "url": "https://user-api.smzdm.com/lottery/draw",
            "headers": [
                {
                    "name": "Content-Type",
                    "value": "application/x-www-form-urlencoded"
                },
                {
                    "name": "User-Agent",
                    "value": "smzdm_android_V10.4.26 rv:866 (Redmi Note 3;Android10.0;zh)smzdmapp"
                },
                {
                    "name": "Cookie",
                    "value": "{{cookie}}"
                }
            ],
            "cookies": [],
            "data": "weixin=1&basic_v=0&f=android&v=10.4.26&time={{timestamp()|int * 1000}}&sign={{(\"basic_v=0&f=android&time=\" ~ (timestamp()|int * 1000)|string ~ \"&v=10.4.26&weixin=1&key=apr1$AwP!wRRT$gJ/q.X24poeBInlUJC\")|md5|upper}}"
        },
        "rule": {
            "success_asserts": [
                {
                    "re": "\"error_code\":\\s*\"[0-9]\"",
                    "from": "content"
                }
            ],
            "failed_asserts": [],
            "extract_variables": [
                {
                    "re": "\"error_msg\":\\s*\"([^\"]+)\"",
                    "from": "content",
                    "name": "lottery_msg"
                }
            ]
        }
    },
    {
        "comment": "延时1秒",
        "request": {
            "method": "GET",
            "url": "api://util/delay/1",
            "headers": [],
            "cookies": [],
            "data": ""
        },
        "rule": {
            "success_asserts": [
                {
                    "re": "200",
                    "from": "status"
                }
            ]
        }
    },
    {
        "comment": "日志输出",
        "request": {
            "method": "POST",
            "url": "api://util/unicode",
            "headers": [],
            "cookies": [],
            "data": "msg=什么值得买签到完成 - {{checkin_msg|default('签到成功')}} - 金币:{{cgold|default('0')}} - 银元:{{pre_re_silver|default('0')}}"
        },
        "rule": {
            "success_asserts": [
                {
                    "re": "200",
                    "from": "status"
                }
            ]
        }
    }
]